---
import GitHubIcon from './GitHubIcon.astro';
import { caseNavUrl } from '../data/primary-case-nav';
import type { Project } from '../data/projects';

interface Props {
	project: Project;
	githubCta: string;
	demoYoutubeCta: string;
	projectImageAltSuffix: string;
}

const { project, githubCta, demoYoutubeCta, projectImageAltSuffix } = Astro.props;
const isPrimary = project.tier === 'primary';
const imgAlt = `${project.title}${projectImageAltSuffix}`;
const repoUrl = project.repoUrl;
const navUrl = caseNavUrl(project);
const titleHref = navUrl ?? repoUrl;
const caseNavAttrs = navUrl ? { 'data-case-nav-url': navUrl } : {};
const isLogoMedia = isPrimary && project.imageSrc && project.imagePresentation === 'logo';
const caseWhy = isPrimary ? project.why : project.summary;
const howLines = isPrimary ? project.how : [];
const demoUrl = isPrimary ? project.demoUrl : undefined;
const imageSrc = isPrimary ? project.imageSrc : undefined;
---

<article
	class:list={['case', imageSrc && 'case--with-media', isLogoMedia && 'case--media-logo']}
	id={project.slug}
	data-project-slug={project.slug}
	data-project-tier={project.tier}
	{...caseNavAttrs}
>
	<div class="case__main">
		<header class="case__top">
			<h3 class="case__title">
				<span class="case__title-start">
					{
						repoUrl ? (
							<>
								<a class="case__title-link" href={titleHref} target="_blank" rel="noopener noreferrer">
									{project.title}
								</a>
								<a
									class="case__github-btn"
									href={repoUrl}
									target="_blank"
									rel="noopener noreferrer"
									aria-label={githubCta}
								>
									<GitHubIcon class="case__github-icon" />
								</a>
							</>
						) : (
							<span class="case__title-text">{project.title}</span>
						)
					}
				</span>
				<span class="case__title-sep" aria-hidden="true"> | </span>
				<span class="case__tech">{project.tech}</span>
			</h3>
		</header>
		<p class="case__why">{caseWhy}</p>
		{
			howLines.length > 0 ? (
				<ul class="case__how">
					{howLines.map((line) => (
						<li>{line}</li>
					))}
				</ul>
			) : null
		}
		{
			demoUrl && (
				<p class="case__cta case__cta-row">
					<a
						class="btn btn--ghost case__cta-demo"
						href={demoUrl}
						target="_blank"
						rel="noopener noreferrer"
					>
						{demoYoutubeCta}
					</a>
				</p>
			)
		}
	</div>
	{
		imageSrc &&
			(navUrl ? (
				<a
					class="case__media-link"
					href={navUrl}
					target="_blank"
					rel="noopener noreferrer"
				>
					<figure class="case__media">
						<img
							class="case__img"
							src={imageSrc}
							alt={imgAlt}
							loading="lazy"
							decoding="async"
							draggable="false"
						/>
					</figure>
				</a>
			) : (
				<figure class="case__media">
					<img
						class="case__img"
						src={imageSrc}
						alt={imgAlt}
						loading="lazy"
						decoding="async"
						draggable="false"
					/>
				</figure>
			))
	}
</article>
