---
import GitHubIcon from './GitHubIcon.astro';
import type { SecondaryProject } from '../data/projects';

interface Props {
	tool: SecondaryProject;
	githubCta: string;
}

const { tool, githubCta } = Astro.props;
const cardAriaLabel = `${tool.title} — ${githubCta}`;
---

<a
	class="small-tool"
	id={tool.slug}
	href={tool.repoUrl}
	target="_blank"
	rel="noopener noreferrer"
	aria-label={cardAriaLabel}
>
	<p class="small-tool__line">
		<span class="small-tool__name-row">
			<strong class="small-tool__name">{tool.title}</strong>
			<span class="small-tool__github-mark" aria-hidden="true">
				<GitHubIcon class="small-tool__github-icon" />
			</span>
		</span>
		<span class="small-tool__sep" aria-hidden="true"> | </span>
		<span class="small-tool__tech">{tool.tech}.</span>
		{' '}
		<span class="small-tool__summary">{tool.summary} </span>
	</p>
</a>
