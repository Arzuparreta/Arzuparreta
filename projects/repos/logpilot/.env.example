# PostgreSQL (used by compose and DATABASE_URL)
POSTGRES_USER=logpilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=logpilot

# -----------------------------------------------------------------------------
# Running `logpilot doctor` / `logpilot ask` ON YOUR LINUX HOST (outside Docker)?
# Put these in your .env — NOT the docker-only hostnames below.
#   DATABASE_URL=postgresql+asyncpg://logpilot:changeme@localhost:5432/logpilot
#   OLLAMA_BASE_URL=http://127.0.0.1:11434   (required for host-side `logpilot` / eval; Compose overrides in-container)
# (Password/user must match POSTGRES_* if you changed them.)
# Inside the logpilot container, Compose uses postgres + host.docker.internal instead.
# -----------------------------------------------------------------------------

# Async SQLAlchemy — hostname `postgres` only resolves inside the Compose network
DATABASE_URL=postgresql+asyncpg://logpilot:changeme@postgres:5432/logpilot

# Ollama on the host when logpilot runs *in Docker* (Linux: extra_hosts host-gateway)
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=llama3

# Ingest: host path is mounted read-only in compose
DOCKER_LOG_ROOT=/var/lib/docker/containers

# Host plain-text logs (syslog, auth, etc.) — default compose bind-mounts HOST_LOG_ROOT -> /var/log
# TEXT_LOG_INGEST=true
# TEXT_LOG_PATHS=
# When JOURNAL_INGEST=true, /var/log/syslog and /var/log/messages are skipped by default (rsyslog dup).
# TEXT_LOG_INCLUDE_JOURNAL_DUPLICATE_PATHS=false
# HOST_LOG_ROOT=/var/log

# --- systemd journal (continuous ingest; mount host /var/log/journal read-only in compose when enabled) ---
# JOURNAL_INGEST=false
# JOURNAL_DIRECTORY=/var/log/journal
# JOURNAL_MACHINE_ID=
# JOURNAL_FLUSH_BATCH_SIZE=32
# One-shot journalctl for answers when there are no embedded journal: rows (default on; not a substitute for ingest+embed)
# JOURNAL_QUERY_ON_DEMAND=true

# Docker socket: Compose mounts `/var/run/docker.sock` read-only by default (live inspect + name enrichment).
# DOCKER_ENRICH_CONTAINER_NAMES=true
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# Read-only Engine API for `logpilot ask` (RestartCount, state) when intent requests it — default on; set false to disable
DOCKER_QUERY_ON_DEMAND=true

# Read-only disk usage (`disk_usage` / df) for `logpilot ask` when intent requests it — default on
# DISK_USAGE_QUERY_ON_DEMAND=true

# Read-only CPU load + thermal (`cpu_thermal`) for `logpilot ask` when intent requests it — default on
# CPU_THERMAL_QUERY_ON_DEMAND=true

# Read-only GPU status (`gpu_status` / nvidia-smi or rocm-smi) for `logpilot ask` when intent requests it — default on
# GPU_STATUS_QUERY_ON_DEMAND=true

# Read-only native service snapshot (`systemctl`) for `logpilot ask` service-status questions — default on
# HOST_SERVICES_QUERY_ON_DEMAND=true
# Compose mounts host `/run/dbus/system_bus_socket` so service questions reach the **host** systemd from the container.
# Implementation uses `systemctl` when possible, else read-only `busctl --system` (typical in Docker).
# If your setup cannot bind that socket, remove that volume from docker-compose.yml and rely on host-side `logpilot ask`
# or ingested logs only.

# Embed worker
EMBED_BATCH_SIZE=32
EMBED_POLL_INTERVAL_S=2.0
INGEST_POLL_INTERVAL_S=1.0

# Optional: force local sentence-transformers instead of Ollama for embeddings
# USE_EMBEDDING_FALLBACK=false

# API (same process as ingest + embed when running `logpilot run`)
LOGPILOT_API_HOST=0.0.0.0
LOGPILOT_API_PORT=8080
LOGPILOT_ENABLE_API=true

LOG_LEVEL=INFO

# Sentence-transformers fallback (768-dim model)
ST_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Query: bounded agent + optional context redaction (see README)
# QUERY_AGENT_MAX_STEPS=5
# QUERY_AGENT_MAX_TOTAL_ROWS=200
# QUERY_AGENT_TIMEOUT_S=120
# QUERY_ANSWER_TIMEOUT_S=300
# QUERY_CONTEXT_REDACT_REGEX=
# Eval HTTP client read timeout per question when using --base-url (default 90s if unset)
# LOGPILOT_EVAL_HTTP_READ_TIMEOUT_S=90
# Eval in-process: max wall-clock seconds per question (intent+retrieval+answer); 0 = no cap (default 180s)
# LOGPILOT_EVAL_INPROCESS_TIMEOUT_S=180
