#!/usr/bin/env sh
# Run the same checks as CI before push. Skip: LOGPILOT_SKIP_HOOKS=1 git push
set -e
if [ -n "$LOGPILOT_SKIP_HOOKS" ]; then
  echo "logpilot: pre-push skipped (LOGPILOT_SKIP_HOOKS is set)" >&2
  exit 0
fi
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT" || exit 1
# Prefer project venv when present so ruff/pytest match `pip install -e ".[dev]"` there.
if [ -z "$PYTHON" ] && [ -x "$ROOT/.venv/bin/python" ]; then
  export PYTHON="$ROOT/.venv/bin/python"
fi
exec make check
