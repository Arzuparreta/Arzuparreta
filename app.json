{
  "expo": {
    "name": "Kitchen Clock",
    "slug": "kitchenclock",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kitchenclock",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1c2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kitchenclock.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1c2e"
      },
      "package": "com.kitchenclock.app",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "SCHEDULE_EXACT_ALARM"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF9F0A",
          "sounds": [
            "./assets/sounds/alert.mp3"
          ]
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "20404ce3-d110-4beb-80d8-da4435cc8551"
      }
    },
    "owner": "arsup"
  }
}
